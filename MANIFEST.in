# Include the license and readme
include LICENSE
include README.md
include README_cn.md
include README_ja.md
include README_ko.md
include CHANGELOG.md
include CONTRIBUTING.md
include CODE_OF_CONDUCT.md
include SECURITY.md
include CITATION.cff

# Include requirements files
include requirements.txt
include pyproject.toml
include setup.py

# Include configuration files
include .editorconfig
include .pre-commit-config.yaml
include tox.ini

# Include documentation (Sphinx source + markdown docs).
# Keep this list tight to avoid noisy sdist build warnings.
recursive-include docs *.md *.rst *.html *.py *.gitkeep
prune docs/build

# Include tests (for source distributions)
recursive-include tests *.py

# Include examples
recursive-include examples *.py *.json

# Include typing marker (PEP 561)
recursive-include pyimgano py.typed

# Exclude development and build artifacts
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store
global-exclude *.egg-info
global-exclude .git*
global-exclude .mypy_cache
global-exclude .pytest_cache
global-exclude .coverage
global-exclude htmlcov
