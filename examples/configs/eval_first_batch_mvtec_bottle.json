    }
  ],
  "models": {
    "include": [
      "vision_ecod",
      "vision_copod",
      "vision_iforest",
      "vision_knn",
      "vision_pca",
      "vision_mahalanobis",
      "vision_dtc",
      "vision_rzscore",
      "vision_pca_md",
      "vision_pixel_mean_absdiff_map",
      "vision_pixel_mad_map"
