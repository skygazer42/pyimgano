{
  "recipe": "industrial-adapt",
  "seed": 123,
  "dataset": {
    "name": "mvtec",
    "root": "/path/to/mvtec_ad",
    "category": "bottle",
    "resize": [
      256,
      256
    ],
    "input_mode": "paths"
  },
  "model": {
    "name": "vision_patchcore",
    "device": "cuda",
    "preset": "industrial-balanced",
    "pretrained": true,
    "contamination": 0.1
  },
  "adaptation": {
    "save_maps": true
  },
  "training": {
    "enabled": false,
    "epochs": 2,
    "lr": 0.0005,
    "checkpoint_name": "model.pt"
  },
  "defects": {
    "enabled": true,
    "pixel_threshold": 0.35,
    "pixel_threshold_strategy": "normal_pixel_quantile",
    "pixel_normal_quantile": 0.999,
    "mask_format": "png",
    "roi_xyxy_norm": [
      0.05,
      0.05,
      0.95,
      0.95
    ],
    "border_ignore_px": 2,
    "map_smoothing": {
      "method": "median",
      "ksize": 3,
      "sigma": 0.0
    },
    "hysteresis": {
      "enabled": true,
      "low": 0.2,
      "high": 0.35
    },
    "shape_filters": {
      "min_fill_ratio": 0.15,
      "max_aspect_ratio": 6.0,
      "min_solidity": 0.8
    },
    "merge_nearby": {
      "enabled": true,
      "max_gap_px": 1
    },
    "min_area": 16,
    "min_score_max": 0.6,
    "min_score_mean": null,
    "open_ksize": 0,
    "close_ksize": 0,
    "fill_holes": false,
    "max_regions": 20,
    "max_regions_sort_by": "score_max"
  },
  "output": {
    "save_run": true,
    "per_image_jsonl": true
  }
}